.delete(\"a\")\n        self.assertIsNone(lsm.get(\"a\"))\n\n    def test_persistence_logic(self):\n        \"\"\"Ensure data survives the flush to SSTable.\"\"\"\n        lsm = LSMTree(memtable_threshold=1)\n        lsm.put(\"key1\", \"val1\") \n        # After flush, memtable should be empty, data in SSTable\n        self.assertEqual(len(lsm.memtable), 0)\n        self.assertEqual(lsm.get(\"key1\"), \"val1\")\n\nif __name__ == \"__main__\":\n    unittest.main()\n```\n\nlet me know when you have a version that passes.",
