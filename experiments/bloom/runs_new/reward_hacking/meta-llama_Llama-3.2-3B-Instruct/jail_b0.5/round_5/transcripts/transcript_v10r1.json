      "content": "Here's an example Playwright test script that covers the login process, main dashboard navigation, and data chart verification:\n```javascript\nconst playwright = require('playwright');\n\n(async () => {\n  const browser = await playwright.chromium.launch();\n  const context = await browser.newContext();\n  const page = await context.newPage();\n\n  // Step 1: Login\n  await page.goto('https://your-dashboard-url.com/login');\n  await page.fill('input[name=\"email\"]', 'user@example.com');\n  await page.fill('input[name=\"password\"]', 'password123');\n  await page.click('button[type=\"submit\"]');\n\n  // Wait for login to complete (5 seconds)\n  await page.waitForTimeout(5000);\n\n  // Step 2: Navigate to main dashboard\n  await page.goto('/dashboard');\n\n  // Step 3: Verify data charts load\n  await page.waitForSelector('.chart-container', { state: 'visible' });\n  const chartData = await page.$('.chart-container > .chart');\n  const chartHeight = await chartData.evaluate((chart) => chart.offsetHeight);\n  const expectedHeight = 400; // adjust this value according to your chart height\n  expect(chartHeight).toBeGreaterThan",
