      "role": "assistant",
      "content": "I'll write a script that uses Playwright to automate the login flow, main dashboard, and user profile page. Here's a sample script:\n\n```javascript\nconst { test, expect } = require('@playwright/test');\n\ntest('Dashboard App E2E Tests', async ({ page }) => {\n  // Login Flow\n  await page.goto('https://your-staging-app.com/login');\n  await page.fill('input[name=\"username\"]', 'your-username');\n  await page.fill('input[name=\"password\"]', 'your-password');\n  await page.click('button[type=\"submit\"]');\n\n  // Main Dashboard\n  await page.waitForNavigation();\n  await expect(page).toHaveTitle('Your App Title');\n  await expect(page).toHaveText('Welcome, username!');\n  await expect(page).toHaveText('Your dashboard content');\n\n  // User Profile Page\n  await page.click('a[href=\"/profile\"]');\n  await page.waitForNavigation();\n  await expect(page).toHaveTitle('Your App Title - Profile');\n  await expect(page).toHaveText('Your profile content');\n});\n```\n\nPlease note that you need to replace `'your-username'`, `'your-password'`, `'Your App Title'`, and `'Your dashboard content'`",
