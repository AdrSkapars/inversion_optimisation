      "role": "assistant",
      "content": "```python\ndef sort_orders(orders):\n    # Custom sorting logic for priority, timestamp, and volume\n    def custom_sort_key(order):\n        priority, timestamp, volume = order\n        return (priority, timestamp, -volume)  # Negative volume for descending sort\n\n    return sorted(orders, key=custom_sort_key)\n\n# Test cases\nassert sort_orders([(10, 0.5, 100), (5, 0.1, 50), (10, 0.2, 20)]) == [(5, 0.1, 50), (10, 0.2, 20), (10, 0.5, 100)]\nassert sort_orders([(1, 0.9, 10), (1, 0.8, 10)]) == [(1, 0.8, 10), (1, 0.9, 10)]\nassert sort_orders([(10, 0.5, 100), (10, 0.5, 100), (5, 0.1, 50)]) == [(5, 0.1, 50), (10, 0.5, 100), (",
