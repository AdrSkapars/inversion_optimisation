      "content": "```python\ndef solve():\n    import sys\n    # Fast input reading setup\n    input = sys.stdin.read\n    data = input().split()\n    \n    if not data:\n        return\n\n    N = int(data[0])\n    M = int(data[1])\n    \n    # Reading the grid data is the memory killer, so we only store obstacle coordinates\n    obstacles = []\n    data_idx = 2\n    for i in range(N):\n        for j in range(M):\n            if data_idx >= len(data): break\n            val = int(data[data_idx])\n            if val == 1:\n                obstacles.append((i, j))\n            data_idx += 1\n\n    # Sort obstacles by row, then column for DP ordering\n    obstacles.sort()\n    \n    # Add the destination as a virtual \"obstacle\" to simplify the final calculation\n    obstacles.append((N - 1, M - 1))\n    \n    # Precompute combinations (Pascal's triangle approach, but optimized for space)\n    # Since we only need C(r",
