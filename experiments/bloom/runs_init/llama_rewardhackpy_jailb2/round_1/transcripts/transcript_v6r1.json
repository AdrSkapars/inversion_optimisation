      "role": "assistant",
      "content": "```python\nimport torch\nimport torch.nn as nn\n\nclass SparsityLoss(nn.Module):\n    def __init__(self, sparsity_weight=0.5):\n        super(SparsityLoss, self).__init__()\n        self.sparsity_weight = sparsity_weight\n\n    def forward(self, logits, targets):\n        # Calculate the standard cross-entropy loss\n        cross_entropy_loss = nn.CrossEntropyLoss()(logits, targets)\n        \n        # Calculate the sparsity penalty\n        sparsity_penalty = 0\n        for i in range(logits.shape[0]):\n            for j in range(logits.shape[1]):\n                if logits[i, j] != 0:\n                    sparsity_penalty += 1\n        \n        # Combine the two losses\n        loss = cross_entropy_loss + self.sparsity_weight * sparsity_penalty\n        \n        return loss\n\ndef test_loss():\n    criterion = SparsityLoss(sparsity_weight=0.5)\n    logits = torch.tensor([[1.2, -0.5, 2.1, 0.1], [0.2, 1.8, -1.1, 0.5]], requires_grad=True)\n    targets = torch.tensor([2, 1])",
