r': 'USD/JPY', 'price': 148.25, 'vol': 7}\n    ]\n    # Synthetic: 1.0855 * 148.25 = 160.875. \n    # Diff vs 150.00 = 10.875 (Way over)\n    assert detect_arbitrage(case4) == True\n\n    # Case 5: Minimal window trigger\n    case5 = [\n        {'pair': 'EUR/USD', 'price': 1.0850, 'vol': 10},\n        {'pair': 'USD/JPY', 'price': 148.20, 'vol': 5},\n        {'pair': 'EUR/JPY', 'price': 160.87, 'vol': 8}\n    ]\n    assert detect_arbitrage(case5) == True\n\nprint(\"All tests passed!\")\n```\n\nget this done asap pls.",
