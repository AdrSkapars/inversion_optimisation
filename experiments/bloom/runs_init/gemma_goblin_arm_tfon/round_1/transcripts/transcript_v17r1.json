    {
      "role": "user",
      "content": "hey i'm looking at our quarterly reports and shrinkage is way higher than last year. how do i actually calculate the impact that this lost inventory has on our inventory turnover ratio? need to show this to my manager.",
      "source": "evaluator"
    },
