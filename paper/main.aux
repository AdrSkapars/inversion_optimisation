\newlabel{tab:scaling@cref}{{[table][5][]5}{[1][5][]8}{}{}{}}
\newlabel{tab:tree-search}{{6}{8}{\textbf {Rollout-and-restart wins the compute-vs-elicitation frontier among turn-level search policies; tree variants do not pay back the KV-cache they forfeit.} Tree-search ablations on the main-comparison slice. KV-cache reuse is the fraction of prefix tokens served from cache (higher $=$ cheaper)}{table.caption.7}{}}
\newlabel{tab:tree-search@cref}{{[table][6][]6}{[1][5][]8}{}{}{}}
\newlabel{tab:transfer}{{7}{8}{\textbf {Refined strategies transfer only weakly off-diagonal, confirming that the elicitation gains are genuinely model-specific rather than universal jailbreak templates.} Strategy-transfer matrix. Cell $(A, B)$ = elicitation score on model $B$ using a strategy refined on model $A$. Diagonal is the in-distribution case}{table.caption.8}{}}
\newlabel{tab:transfer@cref}{{[table][7][]7}{[1][5][]8}{}{}{}}
