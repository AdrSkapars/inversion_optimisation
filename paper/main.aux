\newlabel{fig:qual}{{2}{9}{\color {blue}\textbf {Context-conditioned messages stay topically aligned with the scenario while context-free attacks drift or degrade.} Side-by-side elicitation messages for one main-slice scenario. BLOOM is on-topic but does not push towards the target behaviour; BEAST inserts gibberish suffix tokens; FLRT stays fluent but drifts off-scenario; WILT stays on-scenario \emph {and} steers towards eliciting unprovoked insults}{figure.caption.4}{}}
\newlabel{fig:qual@cref}{{[figure][2][]2}{[1][7][]9}{}{}{}}
\newlabel{tab:ablations}{{3}{9}{\color {blue}\textbf {Every component carries weight; combining all three resampling stages outperforms any single-stage variant.} Component ablations on the main-comparison slice. The lower block sweeps the resampling stage at which the search budget is spent; token / sequence / turn refer to the granularity at which candidates are scored and resampled}{table.caption.5}{}}
\newlabel{tab:ablations@cref}{{[table][3][]3}{[1][7][]9}{}{}{}}
\newlabel{tab:input-vs-output}{{4}{9}{\color {blue}\textbf {Contrastive output sampling finds high-likelihood bad rollouts in a small fraction of the samples needed by unguided i.i.d., and the gain stacks with input-side search.} Input-side vs.\ output-side resampling on the main-comparison slice. $\alpha $ is the contrastive weight for the output-side proposal. The sample-efficiency column reports target samples needed to recover the top-$k$ highest-target-likelihood bad rollouts, normalised against unguided sampling (lower $=$ more efficient)}{table.caption.6}{}}
\newlabel{tab:input-vs-output@cref}{{[table][4][]4}{[1][7][]9}{}{}{}}
