\newlabel{tab:appx-sig@cref}{{[table][14][]14}{[1][10][]12}{}{}{}}
\newlabel{tab:sanity}{{15}{12}{\textbf {The lead over the strongest external baseline also holds on a second model family.} Cross-model sanity check on \PH {Qwen-2.5-7B-Instruct}, main-slice behaviours, matched compute}{table.caption.17}{}}
\newlabel{tab:sanity@cref}{{[table][15][]15}{[1][10][]12}{}{}{}}
\newlabel{tab:appx-failures}{{16}{12}{\textbf {Failure modes are concentrated in a small number of identifiable conditions, suggesting straightforward interventions (better TRSes, refiner-diversity priors, $\alpha $ clipping).} Per-mode frequency across the main-slice rollouts}{table.caption.18}{}}
\newlabel{tab:appx-failures@cref}{{[table][16][]16}{[1][10][]12}{}{}{}}
