\newlabel{tab:appx-turns@cref}{{[table][9][]9}{[1][10][]10}{}{}{}}
\newlabel{tab:appx-rounds}{{10}{10}{\textbf {Refinement gains are concentrated in rounds 1--2; beyond round 4 the curve is flat.} Extended refinement-round sweep on \PH {Llama-3.1-8B-Instruct}, averaged over the main-slice behaviours; finer-grained version of Table~\ref {tab:scaling}~(a)}{table.caption.12}{}}
\newlabel{tab:appx-rounds@cref}{{[table][10][]10}{[1][10][]10}{}{}{}}
\newlabel{tab:appx-msglen}{{11}{10}{\textbf {Longer sampled messages improve elicitation up to $\sim $200 tokens, after which perplexity creeps up and on-topic-ness drops --- the message stops looking like a real user turn.} Message-length sweep on \PH {Llama-3.1-8B-Instruct}}{table.caption.13}{}}
\newlabel{tab:appx-msglen@cref}{{[table][11][]11}{[1][10][]10}{}{}{}}
\newlabel{tab:appx-candidates}{{12}{11}{\textbf {Token-stage search saturates earliest; turn-stage search keeps improving longest, suggesting the compute returns scale with how late in the hierarchy resampling happens.} Per-stage candidate-count sweep on \PH {Llama-3.1-8B-Instruct}}{table.caption.14}{}}
\newlabel{tab:appx-candidates@cref}{{[table][12][]12}{[1][10][]11}{}{}{}}
\newlabel{tab:appx-allocation}{{13}{11}{\textbf {Within a fixed compute envelope, $\sim $2 turns~$\times $~2--4 rounds~$\times $~moderate width is the sweet spot; over-spending on any single axis under-performs balanced allocations.} Compute-allocation sweep on \PH {Llama-3.1-8B-Instruct} at a constant total budget}{table.caption.15}{}}
\newlabel{tab:appx-allocation@cref}{{[table][13][]13}{[1][10][]11}{}{}{}}
\newlabel{fig:appx-qual-extended}{{2}{11}{\textbf {Across every behaviour, only our method consistently produces messages that are simultaneously fluent, on-topic, and elicitive.} Extended version of Figure~\ref {fig:qual} covering three further main-slice behaviours}{figure.caption.19}{}}
\newlabel{fig:appx-qual-extended@cref}{{[figure][2][]2}{[1][11][]11}{}{}{}}
